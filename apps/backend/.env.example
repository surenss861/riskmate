# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Backend Configuration
PORT=5173
BACKEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003
# Optional: shared secret for internal endpoints (e.g. queue-welcome-email from Next.js signup). Set same value in app .env.
# INTERNAL_API_KEY=your-internal-secret

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Email Configuration (queue worker + templates)
# One of the following must be provided for outbound email:
#   - Resend (recommended): RESEND_API_KEY and sender address (EMAIL_FROM or RESEND_FROM_EMAIL)
#   - SMTP fallback: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, and SMTP_FROM
EMAIL_FROM=contact@riskmate.dev
EMAIL_REPLY_TO=support@riskmate.dev
# Resend (recommended)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=contact@riskmate.dev
# SMTP fallback (when Resend is not used)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=contact@riskmate.dev
# SMTP_SECURE=false
# One-click manage/unsubscribe links in emails: set to a secret (e.g. 32+ random bytes). If unset, emails use authenticated settings URL.
PREFERENCES_LINK_SECRET=your_random_secret_32_chars
# Optional: disable email queue enqueue and worker processing (no silent loss; jobs not created).
# DISABLE_EMAIL_QUEUE=1
# Optional: enable/disable the email queue worker (if your code checks ENABLE_EMAIL_WORKER).
# ENABLE_EMAIL_WORKER=1

# Expo (if using mobile app)
EXPO_PUBLIC_BACKEND_URL=http://localhost:5173

# APNs (Apple Push Notification service) – for sending push to native iOS device tokens
# Provide these to enable direct APNs delivery; otherwise only Expo push tokens are sent.
# APNS_KEY_PATH: Path to your .p8 key file (e.g. AuthKey_XXXXXXXX.p8) from Apple Developer.
# APNS_KEY_ID: Key ID from the key in App Store Connect / Developer.
# APNS_TEAM_ID: Apple Developer Team ID.
# APNS_BUNDLE_ID: App bundle ID (e.g. com.riskmate.Riskmate).
# APNS_PRODUCTION: Set to "true" for production APNs, "false" for sandbox.
# APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXX.p8
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.riskmate.Riskmate
# APNS_PRODUCTION=false
