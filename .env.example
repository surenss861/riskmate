# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# Backend API URL (canonical - use this in production)
# Production: https://api.riskmate.dev
# Development: http://localhost:5173 (set in .env.local only, never commit)
NEXT_PUBLIC_API_URL=https://api.riskmate.dev
# Legacy support (will be removed)
NEXT_PUBLIC_BACKEND_URL=https://api.riskmate.dev
# Required for webhook delivery SLA: backend URL and internal secret for worker wake-up after enqueue.
# Use BACKEND_URL only (not NEXT_PUBLIC_BACKEND_URL) so the URL is not inlined into the client bundle.
# Without these, deliveries are still processed on the next poll (~2s); with them, sub-second delivery.
# BACKEND_URL=https://api.riskmate.dev
# INTERNAL_API_KEY=your-internal-secret

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Email Configuration (backend queue worker + templates; Resend or SMTP)
# Resend (recommended): set RESEND_API_KEY and sender address
# Optional: set DISABLE_EMAIL_QUEUE=1 to skip enqueue and worker processing (no silent loss; jobs not created).
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=contact@riskmate.dev
# One-click manage/unsubscribe links: set to a secret (e.g. 32+ random bytes). If unset, emails use authenticated settings URL.
# PREFERENCES_LINK_SECRET=your_random_secret_32_chars
# Optional: canonical from/reply (backend uses EMAIL_FROM or RESEND_FROM_EMAIL or SMTP_FROM)
# EMAIL_FROM=contact@riskmate.dev
# EMAIL_REPLY_TO=support@riskmate.dev
# SMTP (alternative): set SMTP_* and sender address
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=contact@riskmate.dev
# SMTP_SECURE=false

# Webhooks (backend: internal emit + delivery worker)
# Required for /api/webhooks/emit internal endpoint (e.g. 32+ byte random secret). Must match backend env.
# WEBHOOK_EMIT_SECRET=your_strong_random_secret_32_bytes_or_more
# Optional: max concurrent delivery sends (default 5).
# WEBHOOK_DELIVERY_CONCURRENCY=5
# Optional: worker poll interval in ms (default 5000).
# WEBHOOK_WORKER_INTERVAL_MS=5000
# Optional: set to 1 or true to disable the webhook delivery worker (e.g. read-only or test env).
# DISABLE_WEBHOOK_WORKER=false
# Webhook secret encryption at rest: set to a 32-byte random hex (64 characters) to encrypt secrets in webhook_endpoint_secrets with AES-256-GCM. Next.js encrypts before store; backend worker decrypts before signing. If unset, secrets are stored in plaintext.
# WEBHOOK_SECRET_ENCRYPTION_KEY=your_64_character_hex_key_32_bytes

# Expo (if using mobile app)
EXPO_PUBLIC_BACKEND_URL=http://localhost:5173

# APNs (Apple Push Notification service) – required for iOS push when not using Expo push
# Path to the .p8 key file from Apple Developer; backend reads file contents for token auth
# APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXX.p8
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.riskmate.Riskmate
# APNS_PRODUCTION=false
